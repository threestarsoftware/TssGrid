{
  "name": "@threestarsoftware/tssgrid",
  "version": "0.0.10",
  "description": "軽量・ノービルド・日本語IME堅牢な編集グリッド（vanilla JS / 依存なし / MIT）。Excel ライクな入力画面を <script> タグ1本で。",
  "license": "MIT",
  "author": "ThreeStarSoftware (https://www.threestarsoftware.co.jp/)",
  "homepage": "https://tssgrid.threestarsoftware.co.jp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/threestarsoftware/TssGrid.git"
  },
  "bugs": {
    "url": "https://github.com/threestarsoftware/TssGrid/issues"
  },
  "keywords": [
    "grid",
    "data-grid",
    "datagrid",
    "spreadsheet",
    "table",
    "editable",
    "vanilla-js",
    "no-build",
    "dependency-free",
    "ime",
    "japanese",
    "excel",
    "mit"
  ],
  "main": "src/tssgrid.js",
  "types": "src/tssgrid.d.ts",
  "exports": {
    ".": {
      "types": "./src/tssgrid.d.ts",
      "default": "./src/tssgrid.js"
    },
    "./tssgrid.css": "./src/tssgrid.css",
    "./plugins/*": "./plugins/*",
    "./package.json": "./package.json"
  },
  "unpkg": "src/tssgrid.js",
  "jsdelivr": "src/tssgrid.js",
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/tssgrid.js",
    "src/tssgrid.css",
    "src/tssgrid.d.ts",
    "plugins/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}
